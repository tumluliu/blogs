#!/usr/bin/env sh
# Block pushes that don't build cleanly. Runs `pnpm build` (~1.5s here).
# Catches frontmatter loss, broken image refs that Astro validates,
# schema drift, and stray TS errors in pages/components.
#
# Bypass with `git push --no-verify` if you absolutely must.

set -e

# Run from the repo root no matter where the hook fires from.
cd "$(git rev-parse --show-toplevel)"

# Quietly fall back if pnpm is missing (e.g., obsidian-git on Android, which
# can't run shell hooks at all and won't reach this branch).
if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm not found; skipping pre-push build check" >&2
  exit 0
fi

echo "pre-push: running pnpm build..." >&2
if ! pnpm build >/tmp/blogs-prepush.log 2>&1; then
  echo "" >&2
  echo "pre-push: build FAILED. Push aborted." >&2
  echo "Last 30 lines of build output:" >&2
  tail -30 /tmp/blogs-prepush.log >&2
  echo "" >&2
  echo "Full log: /tmp/blogs-prepush.log" >&2
  echo "Bypass (use sparingly): git push --no-verify" >&2
  exit 1
fi

echo "pre-push: build ok" >&2

# Smoke check: build success != output correct. A broken content loader
# (e.g., one that stores raw markdown but skips renderMarkdown) emits
# pages with an empty <article> body and ~3KB total HTML. If even the
# largest post in dist is suspiciously small, fail the push.
SMOKE_THRESHOLD=20000
LARGEST=$(find dist/posts -name 'index.html' \
  -not -path 'dist/posts/index.html' \
  -exec wc -c {} \; 2>/dev/null \
  | awk '{print $1}' | sort -n | tail -1)
if [ -z "$LARGEST" ] || [ "$LARGEST" -lt "$SMOKE_THRESHOLD" ]; then
  echo "" >&2
  echo "pre-push: post-output smoke check FAILED." >&2
  echo "  Largest dist/posts/<slug>/index.html: ${LARGEST:-0} bytes" >&2
  echo "  Expected at least ${SMOKE_THRESHOLD} bytes." >&2
  echo "  Likely a content-loader regression: pages built but bodies are empty." >&2
  echo "  Bypass (use sparingly): git push --no-verify" >&2
  exit 1
fi
echo "pre-push: smoke check ok (largest post = $LARGEST bytes)" >&2
