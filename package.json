{
  "name": "luliu-blog",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "check:assets": "tsx scripts/check-dead-assets.ts",
    "check:content-paths": "tsx scripts/check-content-image-paths.ts",
    "rename-to-slug": "tsx scripts/rename-to-slug.ts",
    "rename-to-slug:apply": "tsx scripts/rename-to-slug.ts --apply",
    "new-post": "tsx scripts/new-post.ts",
    "new-thought": "tsx scripts/new-thought.ts",
    "cnblogs:fetch": "tsx scripts/cnblogs/fetch.ts",
    "cnblogs:fetch:force": "tsx scripts/cnblogs/fetch.ts --force",
    "cnblogs:convert": "tsx scripts/cnblogs/convert.ts",
