    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/xmlrpc": "^1.3.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
