---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const thoughts = (await getCollection('thoughts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

function fmt(d: Date): string {
  return d.toISOString().slice(0, 10);
}

function postSlug(p: { data: { slug?: string }; id: string }): string {
  return p.data.slug ?? p.id;
}
---
<BaseLayout title="主题没有,内容瞎写 — luliu.me">
  <section class="hero">
    <img class="hero-avatar" src="/images/avatar.png" alt="刘露" width="160" height="160" />
    <p class="hero-poem">芳草伴青山，雲影入湖心，松梢鶴嘯長，蘆屋酣夢沉。</p>
  </section>

  <section>
    <div class="section-head">
      <h2>Recent posts</h2>
      <a href="/posts/">All posts →</a>
    </div>
    {posts.length === 0 && <p>(No posts yet.)</p>}
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <span class="post-date">{fmt(p.data.date)}</span>
          <h3><a href={`/posts/${postSlug(p)}/`}>{p.data.title}</a></h3>
        </li>
      ))}
    </ul>
  </section>

  <section>
    <div class="section-head">
      <h2>Recent thoughts</h2>
      <a href="/thoughts/">All thoughts →</a>
    </div>
    {thoughts.length === 0 && <p>(No thoughts yet.)</p>}
    {thoughts.map((t) => (
      <article class="thought-card">
        <span class="thought-date">{fmt(t.data.date)}</span>
        <p>{t.body?.slice(0, 240)}{(t.body?.length ?? 0) > 240 ? '…' : ''}</p>
      </article>
    ))}
  </section>
</BaseLayout>
