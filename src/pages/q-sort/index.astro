---
// /q-sort/ — Quick Thought capture PWA. See spec at
// docs/superpowers/specs/2026-05-07-quick-thought-pwa-design.md
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#1f2937" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/q-sort-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/icons/q-sort-192.png" />
    <script is:inline>
      // Pre-paint: apply persisted theme before CSS to avoid flash.
      try {
        const t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        }
      } catch {}
    </script>
    <title>q-sort</title>
    <style>
      /* Dark theme (default). */
      :root {
        font-size: 18px;
        --bg: #111827;
        --bg-input: #0b1220;
        --fg: #f9fafb;
        --fg-muted: #9ca3af;
        --border: #1f2937;
        --primary: #2563eb;
        --primary-fg: #ffffff;
        --primary-disabled: #374151;
        --danger: #f87171;
        --success: #34d399;
        --bg-dialog: #1f2937;
        --bg-dialog-border: #374151;
        --backdrop: rgba(0, 0, 0, 0.6);
      }
      :root[data-theme="light"] {
        --bg: #fafaf7;
        --bg-input: #ffffff;
        --fg: #111827;
        --fg-muted: #6b7280;
        --border: #e5e7eb;
        --primary-disabled: #d1d5db;
        --danger: #dc2626;
        --success: #059669;
        --bg-dialog: #ffffff;
        --bg-dialog-border: #d1d5db;
        --backdrop: rgba(0, 0, 0, 0.35);
      }
      @media (min-width: 768px) { :root { font-size: 16px; } }

      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--fg);
        display: flex;
        flex-direction: column;
        padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.25rem;
        padding: 0.6rem 0.9rem;
        font-size: 0.95rem;
        color: var(--fg-muted);
        border-bottom: 1px solid var(--border);
      }
      #status { flex: 1; }
      #status.error { color: var(--danger); }
      #status.ok { color: var(--success); }
      button {
        background: var(--primary);
        color: var(--primary-fg);
        border: 0;
        padding: 0.85rem 1.2rem;
        font-size: 1.05rem;
        border-radius: 0.5rem;
        cursor: pointer;
        min-height: 44px;
      }
      button:disabled { background: var(--primary-disabled); cursor: not-allowed; }
      button.ghost {
        background: transparent;
        color: var(--fg-muted);
        padding: 0.5rem 0.8rem;
        font-size: 1.4rem;
        min-height: 44px;
        line-height: 1;
      }
      main { flex: 1; display: flex; flex-direction: column; }
      textarea {
        flex: 1;
        width: 100%;
        background: var(--bg-input);
        color: var(--fg);
        border: 0;
        padding: 1.1rem;
        /* >=16px CSS prevents iOS Safari from auto-zooming on focus. */
        font-size: 1.1rem;
        line-height: 1.55;
        font-family: inherit;
        resize: none;
        outline: none;
      }
      footer { padding: 0.9rem; }
      footer button { width: 100%; }
      dialog {
        background: var(--bg-dialog);
        color: var(--fg);
        border: 0;
        border-radius: 0.6rem;
        padding: 1.1rem;
        max-width: min(420px, 92vw);
        font-size: 1rem;
      }
      dialog::backdrop { background: var(--backdrop); }
      dialog label { display: block; font-size: 0.95rem; margin-top: 0.6rem; color: var(--fg-muted); }
      dialog input {
        width: 100%;
        padding: 0.65rem 0.7rem;
        margin-top: 0.3rem;
        background: var(--bg-input);
        color: var(--fg);
        border: 1px solid var(--bg-dialog-border);
        border-radius: 0.4rem;
        font-family: inherit;
        font-size: 1.05rem;
      }
      dialog .row { display: flex; gap: 0.5rem; margin-top: 1rem; }
      dialog .row button { flex: 1; }
    </style>
  </head>
  <body>
    <header>
      <span id="status">idle</span>
      <button id="theme-btn" class="ghost" aria-label="Toggle theme">☀</button>
      <button id="settings-btn" class="ghost" aria-label="Settings">⚙</button>
    </header>
    <main>
      <textarea id="body" placeholder="thought…" autofocus inputmode="text" autocapitalize="sentences" spellcheck="true"></textarea>
    </main>
    <footer>
      <button id="publish-btn" disabled>Publish</button>
    </footer>

    <dialog id="settings" aria-labelledby="settings-title">
      <h3 id="settings-title" style="margin: 0 0 0.5rem 0;">Settings</h3>
      <form method="dialog">
        <label for="pat-input">PAT (fine-grained, Contents: Write)</label>
        <input id="pat-input" type="password" autocomplete="off" required />
        <label for="repo-input">Repo (owner/name)</label>
        <input id="repo-input" type="text" autocomplete="off" required />
        <div class="row">
          <button id="settings-clear" type="button" class="ghost">Clear</button>
          <button id="settings-cancel" type="button" class="ghost">Cancel</button>
          <button id="settings-save" type="submit">Save</button>
        </div>
      </form>
    </dialog>

    <script>
      import { buildFilename, buildMarkdown, utf8Base64 } from '../../lib/q-sort/builders';
      import { publishThought } from '../../lib/q-sort/api';
      import { loadConfig, saveConfig, clearConfig } from '../../lib/q-sort/storage';

      const $ = (id) => document.getElementById(id);
      const status = $('status');
      const body = $('body');
      const publishBtn = $('publish-btn');
      const settingsBtn = $('settings-btn');
      const settingsDialog = $('settings');
      const patInput = $('pat-input');
      const repoInput = $('repo-input');
      const themeBtn = $('theme-btn');

      function refreshThemeIcon() {
        // Sun glyph in dark mode (clicking switches to light); moon in light mode.
        const cur = document.documentElement.getAttribute('data-theme');
        themeBtn.textContent = cur === 'light' ? '☾' : '☀';
      }
      themeBtn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme');
        const next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch {}
        refreshThemeIcon();
      });
      refreshThemeIcon();

      let inFlight = false;

      function setStatus(text, kind) {
        status.textContent = text;
        status.className = kind ?? '';
      }

      function refreshPublishEnabled() {
        const cfg = loadConfig();
        const hasBody = body.value.trim().length > 0;
        const hasPat = !!cfg.pat;
        publishBtn.disabled = inFlight || !hasBody || !hasPat;
        if (!hasPat) setStatus('set PAT in settings', 'error');
        else if (status.className === 'error' && status.textContent === 'set PAT in settings') setStatus('idle');
      }

      body.addEventListener('input', refreshPublishEnabled);

      settingsBtn.addEventListener('click', () => {
        const cfg = loadConfig();
        patInput.value = cfg.pat ?? '';
        repoInput.value = cfg.repo;
        settingsDialog.showModal();
      });
      $('settings-cancel').addEventListener('click', () => settingsDialog.close());
      document.querySelector('#settings form').addEventListener('submit', (event) => {
        event.preventDefault();
        const pat = patInput.value.trim();
        const repo = repoInput.value.trim();
        saveConfig(pat, repo);
        settingsDialog.close();
        refreshPublishEnabled();
        setStatus('idle');
      });
      $('settings-clear').addEventListener('click', () => {
        clearConfig();
        patInput.value = '';
        repoInput.value = '';
        settingsDialog.close();
        refreshPublishEnabled();
      });

      publishBtn.addEventListener('click', async () => {
        if (inFlight) return;
        const cfg = loadConfig();
        if (!cfg.pat) { setStatus('set PAT in settings', 'error'); return; }
        const text = body.value.trim();
        if (!text) return;

        inFlight = true;
        refreshPublishEnabled();
        setStatus('publishing…');

        const now = new Date();
        const filename = buildFilename(now);
        const md = buildMarkdown(now, text);
        const contentBase64 = utf8Base64(md);
        const stamp = filename.replace('.md', '').replace(/-(\d{2})(\d{2})$/, ' $1:$2');

        const result = await publishThought({
          fetch: window.fetch.bind(window),
          pat: cfg.pat,
          repo: cfg.repo,
          filename,
          contentBase64,
          message: `thought: ${stamp} via q-sort`,
        });

        inFlight = false;

        if (result.ok) {
          body.value = '';
          setStatus('published — deploying (~2 min)', 'ok');
        } else {
          setStatus(`error: ${result.status} ${result.message ?? ''}`.trim(), 'error');
        }
        refreshPublishEnabled();
      });

      // Initial state
      refreshPublishEnabled();
      body.focus();

      // Service worker registration
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js', { scope: '/q-sort/' }).catch((err) => {
          console.warn('SW registration failed', err);
        });
      }
    </script>
  </body>
</html>
